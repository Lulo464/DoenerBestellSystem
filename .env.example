# ==================== DATABASE ====================
# PostgreSQL Verbindungsstring
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://foodorder:foodorder123@localhost:5432/foodorder"

# ==================== AUTHENTICATION (NextAuth) ====================
# URL der Anwendung (wird für Callbacks verwendet)
NEXTAUTH_URL="http://localhost:3000"

# Geheimer Schlüssel für NextAuth (min. 32 Zeichen)
# Generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# ==================== EMAIL (SMTP) ====================
# SMTP-Host des E-Mail-Providers
SMTP_HOST="smtp.example.com"

# SMTP-Port (typisch: 587 für TLS, 465 für SSL)
SMTP_PORT="587"

# SSL/TLS aktivieren (true/false)
SMTP_SECURE="false"

# SMTP-Benutzername (meist die E-Mail-Adresse)
SMTP_USER="your-email@example.com"

# SMTP-Passwort
SMTP_PASS="your-password"

# Absender-E-Mail-Adresse (für "Von:" Feld in E-Mails)
SMTP_FROM="noreply@example.com"

# ==================== APP SETTINGS ====================
# App-Name - wird überall angezeigt:
# - Browser-Tab Titel
# - Header oben links
# - Login-Seite
# - E-Mail-Header und Footer
# NEXT_PUBLIC_ ist erforderlich für Browser-Sichtbarkeit
NEXT_PUBLIC_APP_NAME="Internes Bestellsystem"

# Fallback APP_NAME (für Server-seitige Nutzung, z.B. E-Mails)
APP_NAME="Internes Bestellsystem"

# ==================== OIDC / SSO (optional) ====================
# Wenn konfiguriert, wird der Credentials-Login deaktiviert und nur SSO angeboten
# Kompatibel mit: Keycloak, Authentik, Okta, und anderen OIDC-Providern

# OIDC Issuer URL (z.B. https://auth.beispiel.de/realms/myrealm)
# Leer lassen um OIDC zu deaktivieren
OIDC_ISSUER=""

# OIDC Client ID
OIDC_CLIENT_ID=""

# OIDC Client Secret
OIDC_CLIENT_SECRET=""

# Anzeigename auf dem SSO-Login Button (optional, default: "SSO")
OIDC_PROVIDER_NAME="SSO"

# E-Mail-Adresse die automatisch SUPER_ADMIN Rolle erhält beim ersten OIDC-Login
# Alle anderen Benutzer starten als EMPLOYEE
OIDC_SUPERADMIN_EMAIL=""
